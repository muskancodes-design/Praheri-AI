# ============================
# Praheri.AI Environment Config
# ============================

APP_NAME=Praheri-AI
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

ANTHROPIC_API_KEY=your_anthropic_api_key_here

DATABASE_URL=postgresql://username:password@localhost:5432/praheri_ai

VECTOR_DB_PROVIDER=chroma

AA_API_URL=
AA_CLIENT_ID=
AA_CLIENT_SECRET=

BROKER_API_KEY=
BROKER_API_SECRET=

SECRET_KEY=replace_with_secure_random_key
JWT_SECRET=replace_with_secure_random_key

ALLOWED_ORIGINS=http://localhost:3000

ENABLE_EXPLAINABILITY=true
ENABLE_AUDIT_LOGS=true
ENABLE_MULTI_AGENT=true
ENABLE_BEHAVIORAL_IMMUNITY_SCORE=true
